# ── Linq Partner API ─────────────────────────────────────────────────────────
# https://linqapp.com/developers
LINQ_API_TOKEN=your_linq_api_token
LINQ_API_BASE_URL=https://api.linqapp.com/api/partner/v3
LINQ_BOT_NUMBER=+1xxxxxxxxxx

# ── Yelp Fusion API ───────────────────────────────────────────────────────────
# https://docs.developer.yelp.com
YELP_API_KEY=your_yelp_api_key

# ── Google Places API (New) ───────────────────────────────────────────────────
# https://console.cloud.google.com → Enable "Places API (New)"
GOOGLE_PLACES_API_KEY=your_google_places_api_key

# ── Google Gemini API ─────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
